{
  "buildCommand": "pnpm build",
  "outputDirectory": ".output",
  "installCommand": "pnpm install",
  "framework": "nuxt",
  "functions": {
    ".output/server/index.mjs": {
      "runtime": "nodejs18.x"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
