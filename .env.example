# 環境變數範例檔案
# 複製此檔案為 .env 並填入實際值

# 應用程式設定
NUXT_PUBLIC_APP_NAME=Destination-Anywhere
NUXT_PUBLIC_APP_DESCRIPTION=旅遊目的地預訂平台

# API 設定
NUXT_PUBLIC_API_BASE=http://localhost:3000/api
NUXT_API_SECRET=your-api-secret-key-here

# 資料庫設定
DATABASE_URL=postgresql://username:password@localhost:5432/destination_anywhere

# Redis 設定 (快取)
REDIS_URL=redis://localhost:6379

# JWT 設定
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# 第三方服務設定
# Google Maps API Key (用於地圖功能)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Stripe API Key (用於支付)
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# SendGrid API Key (用於郵件發送)
SENDGRID_API_KEY=your-sendgrid-api-key

# AWS S3 設定 (用於檔案上傳)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=destination-anywhere-uploads

# TinyMCE 設定
TINYMCE_API_KEY=your-tinymce-api-key

# 社交登入設定
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# 開發環境設定
NODE_ENV=development
PORT=3000

# 日誌設定
LOG_LEVEL=info

# 功能開關
ENABLE_REGISTRATION=true
ENABLE_SOCIAL_LOGIN=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PAYMENT=true

# 安全設定
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 快取設定
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# 圖片上傳設定
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp

# 郵件設定
MAIL_FROM=noreply@destination-anywhere.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-email-password

# 推播通知設定
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# 分析設定
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# SEO 設定
SITE_URL=http://localhost:3000
SITE_NAME=Destination-Anywhere
SITE_DESCRIPTION=專業的旅遊目的地預訂平台
SITE_KEYWORDS=旅遊,目的地,預訂,行程,飯店,機票

# 開發工具
NUXT_DEVTOOLS_ENABLED=true
